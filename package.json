{
  "name": "md-to-pdf-app",
  "version": "1.0.0",
  "description": "Markdown editor with PDF export for macOS and Windows",
  "main": "main.js",
  "scripts": {
    "bundle": "esbuild renderer/editor-src.js --bundle --outfile=renderer/editor-bundle.js --format=iife",
    "start": "npm run bundle && electron .",
    "build": "npm run bundle && electron-builder",
    "build:mac": "npm run bundle && electron-builder --mac",
    "build:win": "npm run bundle && electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "marked": "^14.1.0",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.8",
    "mermaid": "^11.14.0"
  },
  "build": {
    "appId": "com.lilou.mdtopdf",
    "productName": "MD to PDF",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
